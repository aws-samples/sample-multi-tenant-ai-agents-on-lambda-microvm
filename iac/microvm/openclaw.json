{
  "gateway": {
    "mode": "local",
    "bind": "custom",
    "customBindHost": "0.0.0.0",
    "port": 18789,
    "auth": { "mode": "token" },
    "controlUi": { "allowedOrigins": ["*"] }
  },
  "models": {
    "providers": {
      "amazon-bedrock": {
        "baseUrl": "https://bedrock-runtime.us-east-1.amazonaws.com",
        "api": "bedrock-converse-stream",
        "auth": "aws-sdk"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": { "primary": "amazon-bedrock/us.anthropic.claude-haiku-4-5-20251001-v1:0" },
      "heartbeat": { "every": "0m" }
    }
  },
  "plugins": {
    "allow": ["amazon-bedrock"],
    "entries": {
      "amazon-bedrock": {
        "config": {
          "discovery": {
            "enabled": true,
            "region": "us-east-1",
            "providerFilter": ["anthropic"]
          }
        }
      }
    }
  }
}
